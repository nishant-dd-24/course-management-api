# ──────────────────────────────────────────
# Database
# ──────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/course_db
SPRING_DATASOURCE_USERNAME=course_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ──────────────────────────────────────────
# JWT
# Must be a Base64-encoded secret of at least 32 raw bytes.
# Generate with: echo -n "your_secret_key_min_32_chars" | base64
# ──────────────────────────────────────────
JWT_SECRET=your_base64_encoded_secret_min_32_chars
JWT_EXPIRATION_SECONDS=3600
JWT_REFRESH_EXPIRATION_SECONDS=604800

# ──────────────────────────────────────────
# Admin bootstrap
# Created on first start if the email does not already exist.
# ──────────────────────────────────────────
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=changeme
APP_ADMIN_NAME=Admin

# ──────────────────────────────────────────
# Docker image tags (blue-green deployment)
# Set to the Git commit SHA of the image to deploy.
# ──────────────────────────────────────────
IMAGE_TAG_BLUE=latest
IMAGE_TAG_GREEN=latest
