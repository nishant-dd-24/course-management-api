{
  "properties": [
    {
      "name": "app.jwt.secret",
      "type": "java.lang.String",
      "description": "Base64-encoded JWT HMAC secret key."
    },
    {
      "name": "app.jwt.expiration-seconds",
      "type": "java.lang.Long",
      "description": "JWT expiration duration in seconds.",
      "defaultValue": 3600
    },
    {
      "name": "app.jwt.refresh-expiration-seconds",
      "type": "java.lang.Long",
      "description": "Refresh token expiration duration in seconds.",
      "defaultValue": 604800
    }
  ]
}
